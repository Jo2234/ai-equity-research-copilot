# App
APP_ENV=local
APP_NAME=ai-equity-research-copilot
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
LOG_LEVEL=INFO

# Public URLs
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=equity_copilot
POSTGRES_USER=equity_copilot
POSTGRES_PASSWORD=equity_copilot_local
DATABASE_URL=postgresql+psycopg://equity_copilot:equity_copilot_local@localhost:5432/equity_copilot

# Redis / jobs
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Storage
UPLOAD_STORAGE_DIR=./data/uploads
AIERC_DATA_DIR=./data
MAX_UPLOAD_MB=50
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.txt,.md

# Retrieval
DEFAULT_TOP_K=8
MIN_SIMILARITY_SCORE=0.25
CHUNK_TARGET_TOKENS=800
CHUNK_OVERLAP_TOKENS=120
AIERC_EMBEDDING_DIMENSIONS=128
AIERC_CHUNK_TARGET_TOKENS=800
AIERC_CHUNK_OVERLAP_TOKENS=80
AIERC_RETRIEVAL_MIN_SCORE=0.04
AIERC_LOCAL_MODEL_NAME=local-deterministic-grounded-v1
AIERC_LLM_PROVIDER=auto
AIERC_OLLAMA_BASE_URL=http://127.0.0.1:11434
AIERC_OLLAMA_MODEL=gemma3:4b
AIERC_OLLAMA_TIMEOUT_SECONDS=180
AIERC_SEC_USER_AGENT="Your Name your-email@example.com"
AIERC_SEC_MAX_FILING_CHARS=600000

# Models
LLM_PROVIDER=ollama
LLM_MODEL=gemma3:4b
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Cost / observability
ENABLE_REQUEST_LOGGING=true
ENABLE_TOKEN_COST_ESTIMATES=true
OTEL_EXPORTER_OTLP_ENDPOINT=

# Security
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=60
LOCAL_AUTH_DISABLED=true
